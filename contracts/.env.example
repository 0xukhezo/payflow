# ── Deployer ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=                         # deployer wallet private key — fund on all target networks

# ── TEE / Relayer ─────────────────────────────────────────────────────────────
RELAYER_ADDRESS=                     # address that will call PayrollLedger.recordPayment
TEE_PUBLIC_KEY=                      # address derived from backend TEE_PRIVATE_KEY

# ── Chainlink CRE ─────────────────────────────────────────────────────────────
CRE_FORWARDER_ADDRESS=               # Chainlink CRE KeystoneForwarder on target network
                                     # leave empty to use placeholder and call setForwarder() later

# ── Chain RPC URLs (optional — public fallbacks are used if not set) ──────────
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org
FLARE_RPC_URL=https://coston2-api.flare.network/ext/C/rpc

# ── Deployment commands ───────────────────────────────────────────────────────
# npx hardhat run scripts/deploy.js --network coston2
#   → deploys TEEVerifier + PayrollLedger
#   → writes addresses to deployments.json, backend/.env, frontend/.env.local
#
# npx hardhat run scripts/deploy-dispatcher.js --network arbitrum
# npx hardhat run scripts/deploy-dispatcher.js --network base
# npx hardhat run scripts/deploy-dispatcher.js --network sepolia
#   → deploys PayrollDispatcher for the chosen network
#   → writes address to deployments.json, backend/.env, cre-workflow config.staging.json
