PORT=3001

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=                        # https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=           # service_role key (not anon key)

# ── Relayer (signs all swap + bridge transactions) ────────────────────────────
RELAYER_PRIVATE_KEY=                 # EOA that holds USDC during swaps — fund on all chains

# ── Deployed contracts ────────────────────────────────────────────────────────
PAYROLL_DISPATCHER_ADDRESS=          # deploy-dispatcher.js --network arbitrum|base|sepolia

# ── Chain RPC URLs ────────────────────────────────────────────────────────────
ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Uniswap Trading API ───────────────────────────────────────────────────────
UNISWAP_API_KEY=                     # from https://hub.uniswap.org

# ── World ID ──────────────────────────────────────────────────────────────────
WORLD_ID_APP_ID=                     # app_xxxx from developer.worldcoin.org
WORLD_ID_ACTION=verify-employee      # action string — must match frontend IDKit config
RP_ID=                               # from developer.worldcoin.org
RP_SIGNING_KEY=                      # RP signing key

# ── Chainlink CRE (deployed DON mode) ────────────────────────────────────────
# When set, payroll triggers the live DON workflow instead of running a local simulation.
# Get this URL from the CRE dashboard after deploying the workflow.
# Leave empty to keep using local `cre workflow simulate` (development default).
CRE_HTTP_TRIGGER_URL=               # https://gateway.cre.chain.link/trigger/<workflow-id>

# ── SideShift (EVM → Solana cross-chain) ─────────────────────────────────────
SIDESHIFT_SECRET=                    # from https://sideshift.ai/affiliate — needed for order creation
SIDESHIFT_AFFILIATE_ID=              # optional affiliate ID
